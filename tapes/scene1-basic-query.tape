# Scene 1 -- basic query 
# Shows: no quotes needed, markdown renders, response streams token by token

Output scene1-basic-query.gif

Require llm-cli

Set Shell "zsh"
Set FontSize 16
Set Width 854
Set Height 480
Set Padding 0
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Type "llm-cli compare mutex and semaphore in a table only"
Enter
Sleep 4s
